# =============================================================================
# Apollo Deploy — Root .env (shared DB connection for migration scripts)
# =============================================================================
# This file is only used by cross-service migration scripts that need to
# connect to both databases. Each service has its own .env for runtime config.
#
# For PlanetScale:
DB_HOST=eu-west-3.pg.psdb.cloud
DB_PORT=5432
DB_USER=pscale_api_xxxxx.yyyyy
DB_PASSWORD=pscale_pw_xxxxxxxxx
DB_SSLMODE=require

# For standard Postgres:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_SSLMODE=disable
